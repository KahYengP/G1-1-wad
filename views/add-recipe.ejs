<!DOCTYPE html>
<html>
<head>
  <title>Add Recipe</title>
  <style>
    body { margin-left: 80px; margin-right: 80px; font-family: "Times New Roman", Times, serif; }
    nav { border-bottom: 1px solid black; padding: 10px; margin-bottom: 0; }
    nav a { margin-right: 15px; text-decoration: none; color: black; }
  </style>
</head>
<body>

<!-- NAVBAR -->
<% if (user && user.role === 'user') { %>
  <nav style="display: flex; justify-content: space-between;">
    <strong>G1-1</strong>
    <div>
      <a href="/recipe">All Recipes</a>
      <a href="/bookmarks">Bookmark</a>
      <a href="/meal-planner">Meal Planner</a>
      <a href="/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
<% } else if (user && user.role === 'admin') { %>
  <nav style="display: flex; justify-content: space-between;">
    <strong>G1-1</strong>
    <div>
      <a href="/recipe">All Recipes</a>
      <a href="/recipe/add">Create</a>
      <a href="/category">Category</a>
      <a href="/bookmarks">Bookmark</a>
      <a href="/meal-planner">Meal Planner</a>
      <a href="/admin/users">Admin User Management</a>
      <a href="/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
<% } else { %>
  <nav style="display: flex; justify-content: space-between;">
    <strong>G1-1</strong>
    <div>
      <a href="/recipe">All Recipes</a>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    </div>
  </nav>
<% } %>

<h1>Add Recipe</h1>

<form action="/recipe/add" method="POST" enctype="multipart/form-data">

  <label>Title:</label><br>
  <input type="text" name="title" placeholder="Title" required style="width: 100%;"><br><br>

  <label>Ingredients:</label><br>
  <textarea name="ingredients" placeholder="Ingredients" required style="width: 100%; height: 80px;"></textarea><br><br>

  <label>Instructions:</label><br>
  <textarea name="instructions" placeholder="Instructions" required style="width: 100%; height: 100px;"></textarea><br><br>

  <label>Category:</label><br>
  <select name="category" required>
    <option value="">-- Select a Category --</option>
    <% CategoryList.forEach(category => { %>
      <option value="<%= category._id %>"><%= category.categoryName %></option>
    <% }) %>
  </select><br><br>

  <label>Recipe Image:</label><br>
  <input type="file" name="image" accept="image/*"><br><br>

  <div style="display: flex; justify-content: flex-end; gap: 10px; align-items: center;">
  <a href="/recipe" style="padding: 5px 12px; border: 1px solid #ccc; border-radius: 4px; text-decoration: none; color: black; background-color: #f0f0f0; font-family: 'Times New Roman', Times, serif; font-size: 1em;">Back</a>
  <button type="submit" style="background-color: #4da7f1; color: white; border: none; padding: 5px 12px; border-radius: 4px; cursor: pointer; font-family: 'Times New Roman', Times, serif; font-size: 1em;">Add</button>
</div>
</form>

</body>
</html>