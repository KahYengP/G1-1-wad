<!DOCTYPE html>
<html>
<head>
  <title>Add Recipe</title>
</head>
<body>

<h1>Add Recipe</h1>

<form action="/recipe/add" method="POST">

  <input type="text" name="title" placeholder="Title" required><br><br>

  <textarea name="ingredients" placeholder="Ingredients" required></textarea><br><br>

  <textarea name="instructions" placeholder="Instructions" required></textarea><br><br>

  <label for="category">Category:</label>
  <select name="category" id="category" required>
    <option value="">--Select a Category--</option>
    <% CategoryList.forEach(category => { %>
      <option value="<%= category._id %>" aria-required="true"><%= category.categoryName %></option>
    <% }) %>
  </select><br><br>

  <button type="submit">Add</button>

</form>

<a href="/recipe">Back</a>

</body>
</html>