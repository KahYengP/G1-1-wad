<!DOCTYPE html>
<html>
<head>
  <title>Recipes</title>
  <style>
    body { margin-left: 80px; margin-right: 80px; font-family: 'Times New Roman', Times, serif; }
    nav { border-bottom: 1px solid black; padding: 10px; margin-bottom: 0; }
    nav a { margin-right: 15px; text-decoration: none; color: black; }
    .recipe-card { border: 1px solid #ccc; padding: 15px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: flex-start; }
    .recipe-card:hover { border-color: blue; }
    .recipe-card:hover .recipe-title { color: blue; }
    .recipe-info { flex: 1; }
    .recipe-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
    .recipe-title { color: black; }
    .btn { padding: 5px 12px; border-radius: 4px; cursor: pointer; font-size: 0.85em; border: none; }
    .btn-grey { background-color: #f0f0f0; color: black; border: 1px solid #ccc; }
    .btn-blue { background-color: #4da7f1; color: white; font-family: arial; }
    .btn-red { background-color: #e74c3c; color: white; border: none; padding: 5px 12px; border-radius: 4px; cursor: pointer; font-size: 0.85em; }
    .addRecipe { padding: 5px 10px; border: 1px solid black; text-decoration: none; color: black; }
    .addRecipe:hover { background-color: black; color: white; }
  </style>
</head>
<body>

<!-- NAVBAR -->
<% if (user && user.role === 'user') { %>
  <nav style="display: flex; justify-content: space-between;">
    <strong>G1-1</strong>
    <div>
      <a href="/recipe">All Recipes</a>
      <a href="/bookmarks">Bookmark</a>
      <a href="/meal-planner">Meal Planner</a>
      <a href="/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
<% } else if (user && user.role === 'admin') { %>
  <nav style="display: flex; justify-content: space-between;">
    <strong>G1-1</strong>
    <div>
      <a href="/recipe">All Recipes</a>
      <a href="/recipe/add">Create</a>
      <a href="/category">Category</a>
      <a href="/bookmarks">Bookmark</a>
      <a href="/meal-planner">Meal Planner</a>
      <a href="/admin/users">Admin User Management</a>
      <a href="/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
<% } else { %>
  <nav style="display: flex; justify-content: space-between;">
    <strong>G1-1</strong>
    <div>
      <a href="/recipe">All Recipes</a>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    </div>
  </nav>
<% } %>

<!-- Header -->
<div style="display: flex; justify-content: space-between; align-items: center;">
  <h1>Recipes</h1>
  <% if (user) { %>
    <a href="/recipe/add" class="addRecipe">Add Recipe</a>
  <% } %>
</div>

<% if (typeof bookmarkError !== 'undefined' && bookmarkError) { %>
  <div style="background-color: #f8d7da; color: #721c24; padding: 10px; margin-bottom: 20px; border-radius: 5px;">
    <%= bookmarkError %>
  </div>
<% } %>

<form action="/recipe" method="GET" style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px;">
  <input type="text" name="search" placeholder="Search recipes..." value="<%= searchQuery || '' %>" style="padding: 6px; border: 1px solid #ccc; border-radius: 4px; flex: 1;">
  <select name="category" style="padding: 6px; border: 1px solid #ccc; border-radius: 4px;">
    <option value="">All Categories</option>
    <% CategoryList.forEach(cat => { %>
      <option value="<%= cat._id %>" <%= categoryId == cat._id ? 'selected' : '' %>><%= cat.categoryName %></option>
    <% }) %>
  </select>
  <button type="submit" style="padding: 6px 12px; border: none; background-color: #4da7f1; color: white; border-radius: 4px; cursor: pointer;">Search</button>
</form>

<% recipes.forEach(recipe => { %>
  <!-- ✅ view uses query string -->
  <a href="/recipe/view?id=<%= recipe._id %>" style="text-decoration: none; color: inherit;">
    <div class="recipe-card">

      <div style="flex: 1;">
        <h3 class="recipe-title" style="margin: 0 0 5px 0;"><%= recipe.title %></h3>
        <p style="margin: 3px 0;"><strong>Category:</strong> <%= recipe.category ? recipe.category.categoryName : 'Uncategorized' %></p>
        <p style="margin: 3px 0; color: grey; font-size: 0.9em;">Created by: <%= recipe.createdByUsername || recipe.createdBy %></p>
        <p style="margin: 3px 0; color: grey; font-size: 0.9em;">Published on: <%= new Date(recipe.createdAt).toLocaleDateString() %></p>
        <% const reviewCount = reviewCounts[recipe._id.toString()] || 0; %>
        <p style="margin: 3px 0; color: grey; font-size: 0.9em;">
          <% if (reviewCount === 0) { %>
            No Reviews yet
          <% } else if (reviewCount === 1) { %>
            1 Review
          <% } else { %>
            <%= reviewCount %> Reviews
          <% } %>
        </p>
      </div>

      <div class="recipe-actions" onclick="event.stopPropagation();">

        <% if (user) { %>
          <form action="/bookmark/create" method="POST">
            <input type="hidden" name="recipeId" value="<%= recipe._id %>">
            <button type="submit" class="btn btn-grey">Save Bookmark</button>
          </form>
        <% } %>

        <% if (user && (user.role === 'admin' || user.email === recipe.createdBy)) { %>
          <a href="/recipe/edit?id=<%= recipe._id %>" class="btn btn-blue" onclick="event.stopPropagation();" style="text-decoration: none; text-align: center;">Edit</a>
        <% } %>

        <% if (user && (user.role === 'admin' || user.email === recipe.createdBy)) { %>
          <form action="/recipe/delete" method="POST">
            <input type="hidden" name="id" value="<%= recipe._id %>">
            <button onclick="event.stopPropagation(); return confirm('Delete this recipe?')" class="btn btn-red">Delete</button>
          </form>
        <% } %>

      </div>

    </div>
  </a>
<% }) %>

</body>
</html>