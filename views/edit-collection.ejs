 <style>
    body { margin-left: 80px; margin-right: 80px; 
   
    font-family: "Times New Roman", Times, serif;}
  </style>

<h1>Edit Collection</h1>

<form action="/collections/update/<%= collection._id %>" method="POST">

    <label>Name:</label>
    <input type="text" name="name" value="<%= collection.name %>" required>

    <br><br>

    <label>Description:</label>
    <input type="text" name="description" value="<%= collection.description %>">

    <br><br>

    <button type="submit">Update</button>

</form>