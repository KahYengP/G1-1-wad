<html>
<head>
  <title>Category List</title> <!-- Title displayed in the browser tab -->
</head>
<body>

  <!-- EJS conditional block: Check if there are any category list -->
  <% if (CategoryList.length === 0) { %>
    <p>No categories yet.</p> <!-- Message when there is no category -->
  <% } else { %>

    <h2>Category List</h2>
    <!-- EJS loop to render each category -->
    <% CategoryList.forEach(i => { %>
        <p><strong>Category: <%= CategoryList.i %></strong></p> 
      <hr>
    <% }); %>
  <% } %>
     
</body>
</html>