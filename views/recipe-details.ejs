<!DOCTYPE html>
<html>
<head>
  <title>Recipe Details</title>
  <style>
    body { margin-left: 80px; margin-right: 80px; }
    nav { border-bottom: 1px solid black; padding: 10px; margin-bottom: 0; }
    nav a { margin-right: 15px; text-decoration: none; color: black; }
    .review-card { border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; }
    .star { color: gold; }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav style="display: flex; justify-content: space-between;">
  <strong>Logo & Name</strong>
  <div>
    <a href="/recipe">All Recipes</a>
    <a href="/bookmarks">Bookmark</a>
    <a href="/profile">Profile</a>
    <a href="/logout">Logout</a>
  </div>
</nav>

<!-- RECIPE DETAIL -->
<div>
  <br>

  <!-- Recipe Info -->
<div style="display: flex; gap: 20px; align-items: flex-start; margin-bottom: 20px;">

  <!-- Left: Image -->
  <img src="<%= recipe.image || '/images/default.jpg' %>"
       style="width: 200px; height: 200px; object-fit: cover; border-radius: 5px; flex-shrink: 0;"
       alt="Recipe Image">

  <!-- Right: Details -->
  <div>
    <h2 style="margin: 0 0 10px 0;"><%= recipe.title %></h2>
    <p><strong>Category:</strong> <%= recipe.category ? recipe.category.categoryName : 'Uncategorized' %></p>
    <p><strong>Ingredients:</strong> <%= recipe.ingredients %></p>
    <p><strong>Instructions:</strong> <%= recipe.instructions %></p>
    <p><strong>Created by:</strong> <%= recipe.createdByUsername || recipe.createdBy %></p>
    <p><strong>Published on:</strong> <%= new Date(recipe.createdAt).toLocaleDateString() %></p>
  </div>

</div>
  


  <!-- REVIEWS -->
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <h3>Review</h3>
<a href="/review/add/<%= recipe._id %>" style="padding: 5px 10px; border: 1px solid black; text-decoration: none; color: black;">Write a review</a>  </div>

  <% if (reviews && reviews.length > 0) { %>
    <% reviews.forEach(review => { %>
      <div class="review-card">

        <div style="display: flex; justify-content: space-between;">
        <div>
          <strong><%= review.username %></strong>
          <span style="color: grey; margin-left: 10px; font-size: 0.9em;">
          <% if (review.updatedAt) { %>
            Edited: <%= new Date(review.updatedAt).toLocaleDateString() %>
          <% } else { %>
            Posted: <%= new Date(review.createdAt).toLocaleDateString() %>
          <% } %>
          </span> 
        </div>

        <!-- Edit/Delete only for review owner -->
        <% if (user && user._id.toString() === review.userId.toString()) { %>
          <span>
            <a href="/review/edit/<%= review._id %>">Edit</a> |
            <a href="/review/delete/<%= review._id %>"
              onclick="return confirm('Delete this review?')" style="color: red;">Delete</a>
          </span>
        <% } %>
      </div>

        <!-- Stars -->
        <div>
          <% for (let i = 1; i <= 5; i++) { %>
            <span class="star"><%= i <= review.rating ? '★' : '☆' %></span>
          <% } %>
        </div>

        <p><%= review.content %></p>
      </div>
    <% }) %>
  <% } else { %>
    <p>No reviews yet. Be the first to write one!</p>
  <% } %>

</div>

</body>
</html>