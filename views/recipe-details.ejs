<!DOCTYPE html>
<html>
<head>
  <title>Recipe Details</title>
  <style>
    body { margin-left: 80px; margin-right: 80px; font-family: 'Times New Roman', Times, serif }
    nav { border-bottom: 1px solid black; padding: 10px; margin-bottom: 0; }
    nav a { margin-right: 15px; text-decoration: none; color: black; }
    .review-card { border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; }
    .star { color: gold; }
    .writeReview {padding: 5px 10px; border: 1px solid black; text-decoration: none; color: black;}
    .writeReview:hover {background-color: black; color: white;}
  </style>
</head>
<body>

<!-- NAVBAR -->
<% if (user && user.role === 'user') { %>
  <nav style="display: flex; justify-content: space-between;">
    <strong>G1-1</strong>
    <div>
      <a href="/recipe">All Recipes</a>
      <a href="/bookmarks">Bookmark</a>
      <a href="/meal-planner">Meal Planner</a>
      <a href="/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
<% } else if (user && user.role === 'admin') { %>
  <nav style="display: flex; justify-content: space-between;">
    <strong>G1-1</strong>
    <div>
      <a href="/recipe">All Recipes</a>
      <a href="/recipe/add">Create</a>
      <a href="/category">Category</a>
      <a href="/bookmarks">Bookmark</a>
      <a href="/meal-planner">Meal Planner</a>
      <a href="/admin/users">Admin User Management</a>
      <a href="/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
<% } else { %>
  <nav style="display: flex; justify-content: space-between;">
    <strong>G1-1</strong>
    <div>
      <a href="/recipe">All Recipes</a>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    </div>
  </nav>
<% } %>

<div>
  <br>
  <div style="margin-bottom: 20px;">
    <h2 style="margin: 0 0 10px 0;"><%= recipe.title %></h2>
    <p><strong>Category:</strong> <%= recipe.category ? recipe.category.categoryName : 'Uncategorized' %></p>
    <p><strong>Ingredients:</strong> <%= recipe.ingredients %></p>
    <p><strong>Instructions:</strong> <%= recipe.instructions %></p>
    <p><strong>Created by:</strong> <%= recipe.createdByUsername || recipe.createdBy %></p>
    <p><strong>Published on:</strong> <%= new Date(recipe.createdAt).toLocaleDateString() %></p>
  </div>
  

  <!-- REVIEWS -->
  <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px; margin-bottom: 15px;">
  <div style="display: flex; align-items: center; gap: 8px;">
    <strong style="font-size: 1.2em;">Review</strong>
    <span style="color: grey; font-size: 0.9em;">(<%= reviews.length %> <%= reviews.length === 1 || reviews.length === 0 ? 'Review' : 'Reviews' %>)</span>
  </div>
  <a href="/review/add/<%= recipe._id %>" class="writeReview">Write a review</a>
</div>

  <% if (reviews && reviews.length > 0) { %>
    <% reviews.forEach(review => { %>
      <div class="review-card">

        <div style="display: flex; justify-content: space-between;">
        <div>
          <strong><%= review.username %></strong>
          <span style="color: #808080; margin-left: 10px; font-size: 0.9em;">
          <% if (review.updatedAt) { %>
            Edited: <%= new Date(review.updatedAt).toLocaleDateString() %>
          <% } else { %>
            Posted: <%= new Date(review.createdAt).toLocaleDateString() %>
          <% } %>
          </span> 
        </div>

       <% if (user && user._id.toString() === review.userId.toString()) { %>
          <span>
            <a href="/review/edit/<%= review._id %>" 
              style="padding: 4px 10px; background-color: #4da7f1; color: white; text-decoration: none; border-radius: 4px; font-size: 0.9em; font-family: arial;">Edit</a>
            <a href="/review/delete/<%= review._id %>"
              onclick="return confirm('Delete this review?')"
              style="padding: 4px 10px; background-color: #e74c3c; color: white; text-decoration: none; border-radius: 4px; font-size: 0.9em; margin-left: 5px; font-family: arial;">Delete</a>
          </span>
        <% } %>
      </div>

        <div>
          <% for (let i = 1; i <= 5; i++) { %>
            <span class="star"><%= i <= review.rating ? '★' : '☆' %></span>
          <% } %>
        </div>

        <p><%= review.content %></p>
      </div>
    <% }) %>
  <% } else { %>
    <p>No reviews yet. Be the first to write one!</p>
  <% } %>

</div>

</body>
</html>