<style>
    body { margin-left: 80px; margin-right: 80px; font-family: "Times New Roman", Times, serif; }
    nav { border-bottom: 1px solid black; padding: 10px; margin-bottom: 0; }
    nav a { margin-right: 15px; text-decoration: none; color: black; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 10px; border-bottom: 2px solid #ccc; }
    td { padding: 10px; border-bottom: 1px solid #eee; }
    .btn-blue { background-color: #4da7f1; color: white; border: none; padding: 4px 10px; border-radius: 4px; cursor: pointer; text-decoration: none; font-size: 0.9em; }
    .btn-red { background-color: #e74c3c; color: white; border: none; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 0.9em; }
</style>

<% if (user && user.role === 'user') { %>
<nav style="display: flex; justify-content: space-between;">
  <strong>G1-1</strong>
  <div>
    <a href="/recipe">All Recipes</a>
    <a href="/bookmarks">Bookmark</a>
    <a href="/meal-planner">Meal Planner</a>
    <a href="/profile">Profile</a>
    <a href="/logout">Logout</a>
  </div>
</nav>
<% } else if (user && user.role === 'admin') { %>
<nav style="display: flex; justify-content: space-between;">
  <strong>G1-1</strong>
  <div>
    <a href="/recipe">All Recipes</a>
    <a href="/recipe/add">Create</a>
    <a href="/category">Category</a>
    <a href="/bookmarks">Bookmark</a>
    <a href="/meal-planner">Meal Planner</a>
    <a href="/admin/users">Admin User Management</a>
    <a href="/profile">Profile</a>
    <a href="/logout">Logout</a>
  </div>
</nav>
<% } %>

<h1>Bookmarked Recipes</h1>
<a href="/recipe"><button class="btn-blue">Add Bookmark</button></a>
<br><br>

<% if (bookmarks.length === 0) { %>
    <p>No bookmarks yet.</p>
<% } else { %>
    <table>
        <tr>
            <th>Recipe</th>
            <th>Category</th>
            <th>Note</th>
            <th>Actions</th>
        </tr>

        <% bookmarks.forEach(bookmark => { %>
        <tr>
            <% if (bookmark.recipeId) { %>
                <td><%= bookmark.recipeId.title %></td>
                <td><%= bookmark.category ? bookmark.category.categoryName : "None" %></td>
                <td><%= bookmark.note || "No note" %></td>
                <td style="display: flex; gap: 8px; align-items: center;">
                    <a href="/recipe/view/<%= bookmark.recipeId._id %>" class="btn-blue">View</a>

                    <form action="/bookmark/edit" method="POST" style="margin: 0;">
                        <input type="hidden" name="bookmarkId" value="<%= bookmark._id %>">
                        <button type="submit" class="btn-blue">Edit</button>
                    </form>

                    <form action="/bookmark/delete" method="POST" style="margin: 0;">
                        <input type="hidden" name="bookmarkId" value="<%= bookmark._id %>">
                        <button type="submit" class="btn-red" onclick="return confirm('Delete this bookmark?')">Delete</button>
                    </form>
                </td>
            <% } else { %>
                <td colspan="3" style="color: grey;">Recipe deleted</td>
                <td>
                    <form action="/bookmark/delete" method="POST" style="margin: 0;">
                        <input type="hidden" name="bookmarkId" value="<%= bookmark._id %>">
                        <button type="submit" class="btn-red" onclick="return confirm('Delete this bookmark?')">Delete</button>
                    </form>
                </td>
            <% } %>
        </tr>
        <% }) %>
    </table>
<% } %>