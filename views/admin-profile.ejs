<!DOCTYPE html>
<html>
<head>
  <title>Admin Profile</title>
  <style>
    body { margin-left: 80px; margin-right: 80px; font-family: "Times New Roman", Times, serif; }
    nav { border-bottom: 1px solid black; padding: 10px; margin-bottom: 0; }
    nav a { margin-right: 15px; text-decoration: none; color: black; }
    table { border-collapse: collapse; width: 100%; margin-top: 20px; }
    th, td { padding: 10px; text-align: left; border-bottom: 1px solid #eee; }
    th { border-bottom: 2px solid #ccc; }
    .admin-badge { background-color: #4da7f1; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.9em; font-family: arial; }
    .user-badge { background-color: #777; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.9em; font-family: arial;}
    .btn-blue { background-color: #4da7f1; color: white; border: none; padding: 4px 10px; border-radius: 4px; cursor: pointer; text-decoration: none; font-size: 0.9em; font-family: Arial, sans-serif; }
    .btn-red { background-color: #e74c3c; color: white; border: none; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 0.9em; font-family: Arial, sans-serif; }
    .createBtn {padding: 5px 10px; border: 1px solid black; text-decoration: none; color: black; background-color: white;font-family: "Times New Roman"}
    .createBtn:hover {background-color: black; color: white;}
  </style>
</head>
<body>

<!-- NAVBAR -->
<% if (user && user.role === 'admin') { %>
  <nav style="display: flex; justify-content: space-between;">
    <strong>G1-1</strong>
    <div>
      <a href="/recipe">All Recipes</a>
      <a href="/recipe/add">Create</a>
      <a href="/category">Category</a>
      <a href="/bookmarks">Bookmark</a>
      <a href="/meal-planner">Meal Planner</a>
      <a href="/admin/users">Admin User Management</a>
      <a href="/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
<% } %>

<div style="display: flex; justify-content: space-between; align-items: center;">
  <h1>Admin – User Management</h1>
  <a href="/admin/users/new" class="createBtn">Create New User</a>
</div>

<table>
  <thead>
    <tr>
      <th>Username</th>
      <th>Email</th>
      <th>Role</th>
      <th>Created</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% users.forEach(u => { %>
      <tr>
        <td><%= u.username %></td>
        <td><%= u.email %></td>
        <td>
          <% if (u.role === 'admin') { %>
            <span class="admin-badge">Admin</span>
          <% } else { %>
            <span class="user-badge">User</span>
          <% } %>
        </td>
        <td><%= new Date(u.dateCreated).toLocaleDateString() %></td>
        <td style="display: flex; gap: 8px; align-items: center;">
          <a href="/admin/users/edit?id=<%= u._id %>" class="btn-blue">Edit</a>
          <form action="/admin/users/delete" method="POST">
            <input type="hidden" name="userId" value="<%= u._id %>">
            <button type="submit" class="btn-red" onclick="return confirm('Delete this user?')">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

</body>
</html>